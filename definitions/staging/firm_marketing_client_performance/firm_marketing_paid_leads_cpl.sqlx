--   SELECT
--     reporting_week_end_date,

--     -- Monthly: current month through the latest completed Saturday
--     DATE_TRUNC(reporting_week_end_date, MONTH) AS current_month_start_date,
--     reporting_week_end_date AS current_month_end_date,

