--   FROM client_roster r
--   CROSS JOIN date_windows dw
--   LEFT JOIN google_ads_campaign_union g
--     ON r.client = g.client
--    AND r.am = g.am
--    AND g.segment_date BETWEEN LEAST(dw.prior_month_start_date, dw.prior_2_weeks_start_date)
--                           AND dw.current_month_end_date
--   GROUP BY
--     r.client,
--     r.am,
--     r.SterlingX_Client_ID,
--     r.SterlingX_Client_Name,
