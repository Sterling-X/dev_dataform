config {
    type: "table",
    database: "sterlingx-insights",
    schema: "firm_marketing_googleanalytics4",
    name: "fanashfamily_googleanalytics4_custom_newusers_engaged_sessions",
    tags: ["google analytics 4", "ga4", "newusers engaged sessions", "marketing data", "fanashfamily"],
}

SELECT
    '8a4bb5d3-2988-4b58-901a-d7ebdb015a10' AS SterlingX_Client_ID,
    'Fanash Family Law' AS SterlingX_Client_Name,
    fa.property_id,
    fa.event_date,

    -- dimensions
    JSON_VALUE(fa.dimension_values_json, '$.date') AS date,
    JSON_VALUE(fa.dimension_values_json, '$.firstUserDefaultChannelGroup') AS first_user_default_channel_group,
    JSON_VALUE(fa.dimension_values_json, '$.sessionDefaultChannelGroup') AS session_default_channel_group,

    -- metrics
    SAFE_CAST(JSON_VALUE(fa.metric_values_json, '$.engagedSessions') AS INT64) AS engaged_sessions,
    SAFE_CAST(JSON_VALUE(fa.metric_values_json, '$.newUsers') AS INT64) AS new_users,
    SAFE_CAST(JSON_VALUE(fa.metric_values_json, '$.sessions') AS INT64) AS sessions

FROM `rc-datamart-adminreport.google_analytics4_fanashfamily.fact_ga4_daily_analysis` fa
LEFT JOIN `rc-datamart-adminreport.google_analytics4_fanashfamily.dim_ga4_report` dr
    ON fa.report_id = dr.report_id
WHERE dr.report_category = 'newusers_engaged_sessions'
    AND dr.report_name = 'custom_newusers_engaged_sessions_daily'
