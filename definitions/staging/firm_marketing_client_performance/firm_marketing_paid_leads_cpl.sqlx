config {
    type: "table",
    database: "sterlingx-insights",
    schema: "firm_marketing_client_performance",
    name: "firm_marketing_paid_leads_cpl",
    tags: ["google analytics 4", "ga4", "paid", "leads", "cpl", "monthly", "weekly", "bi-weekly", "client performance data"],
}

WITH client_roster AS (
  SELECT *
  FROM UNNEST([
    STRUCT('Aurit Mediation' AS client, 'Garrett' AS am, '916fb7c7-13bc-4725-8bca-e11e0749da31' AS SterlingX_Client_ID, 'Aurit mediation' AS SterlingX_Client_Name),
    STRUCT('Cutrer Family Law' AS client, 'Dani' AS am, '2e0efe10-f122-4a03-bfa5-7215e2dd7b71' AS SterlingX_Client_ID, 'Cutrer' AS SterlingX_Client_Name),
    STRUCT('Fanash Family Law' AS client, 'Garrett' AS am, '8a4bb5d3-2988-4b58-901a-d7ebdb015a10' AS SterlingX_Client_ID, 'Fanash Family Law' AS SterlingX_Client_Name),
    STRUCT('Gjesdahl Law' AS client, 'Dani' AS am, '17c0939a-2e3d-4728-933d-564183626ec3' AS SterlingX_Client_ID, 'Gjesdahl Law' AS SterlingX_Client_Name),
    STRUCT('Michael Ireland & Associates' AS client, 'Dani' AS am, 'a9b10ec7-4dfe-4058-bdb5-a53e66176eed' AS SterlingX_Client_ID, 'Michael Ireland & Associates' AS SterlingX_Client_Name),
    STRUCT('Johnson Law Group' AS client, 'Garrett' AS am, '0c4e2f26-cf3d-41e3-978f-8cd31726062f' AS SterlingX_Client_ID, 'Johnson Law Group' AS SterlingX_Client_Name),
    STRUCT('Kalish & Jaggars' AS client, 'Dani' AS am, '085566ed-07da-44fc-9292-e77dafdf1b68' AS SterlingX_Client_ID, 'Kalish and Jaggars' AS SterlingX_Client_Name),
    STRUCT('Lancaster Family Law' AS client, 'Dani' AS am, '331dae6a-d0e7-48fe-866e-b068ec98059e' AS SterlingX_Client_ID, 'Lancaster' AS SterlingX_Client_Name),
    STRUCT('MeyerPink' AS client, 'Dani' AS am, '5537c7d2-eb93-4748-bc6a-e236641db089' AS SterlingX_Client_ID, 'Meyer Pink' AS SterlingX_Client_Name),
    STRUCT('Scott M Brown Law' AS client, 'Dani' AS am, '3cf419a4-3d2c-4a8b-8deb-d004496a971d' AS SterlingX_Client_ID, 'Scott M Brown' AS SterlingX_Client_Name),
    STRUCT('Sterling Lawyers' AS client, 'Dani' AS am, '99584197-537f-4cf5-80b4-29c99205f07a' AS SterlingX_Client_ID, 'Sterling Lawyers' AS SterlingX_Client_Name)
  ])
),

google_ads_campaign_union AS (
  SELECT 'Aurit Mediation' AS client, 'Garrett' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_aurit.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Cutrer Family Law' AS client, 'Dani' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_cutrerlaw.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Fanash Family Law' AS client, 'Garrett' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_fanashfamily.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Gjesdahl Law' AS client, 'Dani' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_gjesdahllaw.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Michael Ireland & Associates' AS client, 'Dani' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_ireland.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Johnson Law Group' AS client, 'Garrett' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_johnsonlaw.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Kalish & Jaggars' AS client, 'Dani' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_kalishjaggars.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Lancaster Family Law' AS client, 'Dani' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_lancasterlaw.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'MeyerPink' AS client, 'Dani' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_meyerpinklaw.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Scott M Brown Law' AS client, 'Dani' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_smb.fct_gads_campaign_daily` g

  UNION ALL

  SELECT 'Sterling Lawyers' AS client, 'Dani' AS am, g.*
  FROM `rc-datamart-adminreport.google_ads_sterlinglawyers.fct_gads_campaign_daily` g
),

date_windows AS (
  SELECT
    CURRENT_DATE() AS report_end_date,

    -- 90 Days
    DATE_SUB(CURRENT_DATE(), INTERVAL 89 DAY) AS current_90_days_start_date,
    CURRENT_DATE() AS current_90_days_end_date,

    DATE_SUB(CURRENT_DATE(), INTERVAL 179 DAY) AS prior_90_days_start_date,
    DATE_SUB(CURRENT_DATE(), INTERVAL 90 DAY) AS prior_90_days_end_date,

    DATE_SUB(DATE_SUB(CURRENT_DATE(), INTERVAL 89 DAY), INTERVAL 1 YEAR) AS yoy_90_days_start_date,
    DATE_SUB(CURRENT_DATE(), INTERVAL 1 YEAR) AS yoy_90_days_end_date,

    -- 30 Days
    DATE_SUB(CURRENT_DATE(), INTERVAL 29 DAY) AS current_30_days_start_date,
    CURRENT_DATE() AS current_30_days_end_date,

    DATE_SUB(CURRENT_DATE(), INTERVAL 59 DAY) AS prior_30_days_start_date,
    DATE_SUB(CURRENT_DATE(), INTERVAL 30 DAY) AS prior_30_days_end_date,

    DATE_SUB(DATE_SUB(CURRENT_DATE(), INTERVAL 29 DAY), INTERVAL 1 YEAR) AS yoy_30_days_start_date,
    DATE_SUB(CURRENT_DATE(), INTERVAL 1 YEAR) AS yoy_30_days_end_date,

    -- 14 Days
    DATE_SUB(CURRENT_DATE(), INTERVAL 13 DAY) AS current_14_days_start_date,
    CURRENT_DATE() AS current_14_days_end_date,

    DATE_SUB(CURRENT_DATE(), INTERVAL 27 DAY) AS prior_14_days_start_date,
    DATE_SUB(CURRENT_DATE(), INTERVAL 14 DAY) AS prior_14_days_end_date,

    DATE_SUB(DATE_SUB(CURRENT_DATE(), INTERVAL 13 DAY), INTERVAL 1 YEAR) AS yoy_14_days_start_date,
    DATE_SUB(CURRENT_DATE(), INTERVAL 1 YEAR) AS yoy_14_days_end_date
),

client_rollup AS (
  SELECT
    r.client,
    r.am,
    r.SterlingX_Client_ID,
    r.SterlingX_Client_Name,

    dw.report_end_date,

    dw.current_90_days_start_date,
    dw.current_90_days_end_date,
    dw.prior_90_days_start_date,
    dw.prior_90_days_end_date,
    dw.yoy_90_days_start_date,
    dw.yoy_90_days_end_date,

    dw.current_30_days_start_date,
    dw.current_30_days_end_date,
    dw.prior_30_days_start_date,
    dw.prior_30_days_end_date,
    dw.yoy_30_days_start_date,
    dw.yoy_30_days_end_date,

    dw.current_14_days_start_date,
    dw.current_14_days_end_date,
    dw.prior_14_days_start_date,
    dw.prior_14_days_end_date,
    dw.yoy_14_days_start_date,
    dw.yoy_14_days_end_date,

    MAX(g.segment_date) AS latest_reporting_data_date,

    -- 90 Days Leads
    SUM(CASE WHEN g.segment_date BETWEEN dw.current_90_days_start_date AND dw.current_90_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_90_days_current,
    SUM(CASE WHEN g.segment_date BETWEEN dw.prior_90_days_start_date AND dw.prior_90_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_90_days_prior,
    SUM(CASE WHEN g.segment_date BETWEEN dw.yoy_90_days_start_date AND dw.yoy_90_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_90_days_yoy,

    -- 90 Days Cost
    SUM(CASE WHEN g.segment_date BETWEEN dw.current_90_days_start_date AND dw.current_90_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_90_days_current,
    SUM(CASE WHEN g.segment_date BETWEEN dw.prior_90_days_start_date AND dw.prior_90_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_90_days_prior,
    SUM(CASE WHEN g.segment_date BETWEEN dw.yoy_90_days_start_date AND dw.yoy_90_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_90_days_yoy,

    -- 30 Days Leads
    SUM(CASE WHEN g.segment_date BETWEEN dw.current_30_days_start_date AND dw.current_30_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_30_days_current,
    SUM(CASE WHEN g.segment_date BETWEEN dw.prior_30_days_start_date AND dw.prior_30_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_30_days_prior,
    SUM(CASE WHEN g.segment_date BETWEEN dw.yoy_30_days_start_date AND dw.yoy_30_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_30_days_yoy,

    -- 30 Days Cost
    SUM(CASE WHEN g.segment_date BETWEEN dw.current_30_days_start_date AND dw.current_30_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_30_days_current,
    SUM(CASE WHEN g.segment_date BETWEEN dw.prior_30_days_start_date AND dw.prior_30_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_30_days_prior,
    SUM(CASE WHEN g.segment_date BETWEEN dw.yoy_30_days_start_date AND dw.yoy_30_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_30_days_yoy,

    -- 14 Days Leads
    SUM(CASE WHEN g.segment_date BETWEEN dw.current_14_days_start_date AND dw.current_14_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_14_days_current,
    SUM(CASE WHEN g.segment_date BETWEEN dw.prior_14_days_start_date AND dw.prior_14_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_14_days_prior,
    SUM(CASE WHEN g.segment_date BETWEEN dw.yoy_14_days_start_date AND dw.yoy_14_days_end_date THEN COALESCE(g.conversions, 0) ELSE 0 END) AS paid_leads_14_days_yoy,

    -- 14 Days Cost
    SUM(CASE WHEN g.segment_date BETWEEN dw.current_14_days_start_date AND dw.current_14_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_14_days_current,
    SUM(CASE WHEN g.segment_date BETWEEN dw.prior_14_days_start_date AND dw.prior_14_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_14_days_prior,
    SUM(CASE WHEN g.segment_date BETWEEN dw.yoy_14_days_start_date AND dw.yoy_14_days_end_date THEN COALESCE(g.cost_micros, 0) / 1000000 ELSE 0 END) AS paid_cost_14_days_yoy

  FROM client_roster r
  CROSS JOIN date_windows dw
  LEFT JOIN google_ads_campaign_union g
    ON r.client = g.client
   AND r.am = g.am
   AND g.segment_date BETWEEN LEAST(
                            dw.yoy_90_days_start_date,
                            dw.prior_90_days_start_date,
                            dw.current_90_days_start_date
                          )
                          AND dw.report_end_date
  GROUP BY
    r.client,
    r.am,
    r.SterlingX_Client_ID,
    r.SterlingX_Client_Name,

    dw.report_end_date,

    dw.current_90_days_start_date,
    dw.current_90_days_end_date,
    dw.prior_90_days_start_date,
    dw.prior_90_days_end_date,
    dw.yoy_90_days_start_date,
    dw.yoy_90_days_end_date,

    dw.current_30_days_start_date,
    dw.current_30_days_end_date,
    dw.prior_30_days_start_date,
    dw.prior_30_days_end_date,
    dw.yoy_30_days_start_date,
    dw.yoy_30_days_end_date,

    dw.current_14_days_start_date,
    dw.current_14_days_end_date,
    dw.prior_14_days_start_date,
    dw.prior_14_days_end_date,
    dw.yoy_14_days_start_date,
    dw.yoy_14_days_end_date
)

SELECT
  client,
  am,

  -- 90 Days
  paid_leads_90_days_current,
  paid_leads_90_days_prior,
  paid_leads_90_days_yoy,

  COALESCE(SAFE_DIVIDE(paid_cost_90_days_current, NULLIF(paid_leads_90_days_current, 0)), 0) AS paid_cpl_90_days_current,
  COALESCE(SAFE_DIVIDE(paid_cost_90_days_prior, NULLIF(paid_leads_90_days_prior, 0)), 0) AS paid_cpl_90_days_prior,
  COALESCE(SAFE_DIVIDE(paid_cost_90_days_yoy, NULLIF(paid_leads_90_days_yoy, 0)), 0) AS paid_cpl_90_days_yoy,

  -- 30 Days
  paid_leads_30_days_current,
  paid_leads_30_days_prior,
  paid_leads_30_days_yoy,

  COALESCE(SAFE_DIVIDE(paid_cost_30_days_current, NULLIF(paid_leads_30_days_current, 0)), 0) AS paid_cpl_30_days_current,
  COALESCE(SAFE_DIVIDE(paid_cost_30_days_prior, NULLIF(paid_leads_30_days_prior, 0)), 0) AS paid_cpl_30_days_prior,
  COALESCE(SAFE_DIVIDE(paid_cost_30_days_yoy, NULLIF(paid_leads_30_days_yoy, 0)), 0) AS paid_cpl_30_days_yoy,

  -- 14 Days
  paid_leads_14_days_current,
  paid_leads_14_days_prior,
  paid_leads_14_days_yoy,

  COALESCE(SAFE_DIVIDE(paid_cost_14_days_current, NULLIF(paid_leads_14_days_current, 0)), 0) AS paid_cpl_14_days_current,
  COALESCE(SAFE_DIVIDE(paid_cost_14_days_prior, NULLIF(paid_leads_14_days_prior, 0)), 0) AS paid_cpl_14_days_prior,
  COALESCE(SAFE_DIVIDE(paid_cost_14_days_yoy, NULLIF(paid_leads_14_days_yoy, 0)), 0) AS paid_cpl_14_days_yoy,

  -- Date Frames
  report_end_date,
  latest_reporting_data_date,

  current_90_days_start_date,
  current_90_days_end_date,
  prior_90_days_start_date,
  prior_90_days_end_date,
  yoy_90_days_start_date,
  yoy_90_days_end_date,

  current_30_days_start_date,
  current_30_days_end_date,
  prior_30_days_start_date,
  prior_30_days_end_date,
  yoy_30_days_start_date,
  yoy_30_days_end_date,

  current_14_days_start_date,
  current_14_days_end_date,
  prior_14_days_start_date,
  prior_14_days_end_date,
  yoy_14_days_start_date,
  yoy_14_days_end_date,

  SterlingX_Client_ID,
  SterlingX_Client_Name

FROM client_rollup
ORDER BY
  client





