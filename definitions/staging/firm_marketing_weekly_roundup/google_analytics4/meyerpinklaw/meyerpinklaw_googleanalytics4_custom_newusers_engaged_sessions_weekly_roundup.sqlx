config {
    type: "table",
    database: "sterlingx-insights",
    schema: "firm_marketing_googleanalytics4_weekly_roundup",
    name: "meyerpinklaw_googleanalytics4_custom_newusers_engaged_sessions_weekly_roundup",
    tags: ["google analytics 4", "ga4", "newusers engaged sessions", "marketing data", "meyerpinklaw"],
}

WITH base AS (
    SELECT
        SterlingX_Client_ID,
        SterlingX_Client_Name,
        property_id,
        PARSE_DATE('%Y%m%d', CAST(date AS STRING)) AS report_date,
        first_user_default_channel_group,
        session_default_channel_group,
        engaged_sessions,
        new_users,
        sessions
    FROM `sterlingx-insights.firm_marketing_googleanalytics4.meyerpinklaw_googleanalytics4_custom_newusers_engaged_sessions`
)

SELECT
    SterlingX_Client_ID,
    SterlingX_Client_Name,
    property_id,

    DATE_TRUNC(report_date, WEEK(MONDAY)) AS week_start_date,
    DATE_ADD(DATE_TRUNC(report_date, WEEK(MONDAY)), INTERVAL 6 DAY) AS week_end_date,

    first_user_default_channel_group,
    session_default_channel_group,

    SUM(engaged_sessions) AS engaged_sessions,
    SUM(new_users) AS new_users,
    SUM(sessions) AS sessions
FROM base
GROUP BY 1, 2, 3, 4, 5, 6, 7
